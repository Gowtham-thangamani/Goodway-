# Apache server rules for Goodway static site
ErrorDocument 401 /401.html
ErrorDocument 404 /404.html

# Enforce HTTPS (uncomment when SSL is in place)
# RewriteEngine On
# RewriteCond %{HTTPS} !=on
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redesign consolidation (audit 2026-04-24):
# Contact + Request-a-Quote merged into one tabbed page at /contact.html.
# Fragment (#quote) preserves intent; the RewriteRule [R=301,L,NE] passes
# the #quote anchor through so returning visitors land on the quote tab.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^request-a-quote\.html$ /contact.html#quote [R=301,L,NE]
</IfModule>

# Gzip + brotli
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Long-cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/avif        "access plus 1 year"
  ExpiresByType image/webp        "access plus 1 year"
  ExpiresByType image/png         "access plus 1 year"
  ExpiresByType image/jpeg        "access plus 1 year"
  ExpiresByType text/css          "access plus 1 month"
  ExpiresByType text/javascript   "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType font/woff2        "access plus 1 year"
  ExpiresByType text/html         "access plus 1 hour"
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>
