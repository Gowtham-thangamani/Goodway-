<%- include('../partials/head', { title: 'Lead #' + row.id }) %>
<div class="gwa-shell">
  <%- include('../partials/nav') %>
  <main class="gwa-main">
    <header class="gwa-pagehead">
      <div>
        <a href="/admin/quotes" class="gwa-crumb">← Leads</a>
        <h1><%= row.name %></h1>
        <p class="gwa-sub">Received <%= row.received_at %></p>
      </div>
      <span class="gwa-pill gwa-pill--<%= row.status %>"><%= row.status.replace('_', ' ') %></span>
    </header>
    <%- include('../partials/flash') %>

    <section class="gwa-card">
      <dl class="gwa-dl">
        <div><dt>Name</dt><dd><%= row.name %></dd></div>
        <div><dt>Company</dt><dd><%= row.company || '—' %></dd></div>
        <div><dt>Email</dt><dd><a href="mailto:<%= row.email %>"><%= row.email %></a></dd></div>
        <div><dt>Phone</dt><dd><% if (row.phone) { %><a href="tel:<%= row.phone.replace(/\s/g, '') %>"><%= row.phone %></a><% } else { %>—<% } %></dd></div>
        <div><dt>Sector</dt><dd><%= row.sector || '—' %></dd></div>
        <div><dt>Division</dt><dd><%= row.division || '—' %></dd></div>
        <div><dt>Location</dt><dd><%= row.location || '—' %></dd></div>
        <div><dt>Required by</dt><dd><%= row.timeline || '—' %></dd></div>
        <div><dt>Source</dt><dd><%= row.source %></dd></div>
        <div><dt>IP</dt><dd class="gwa-muted gwa-mono"><%= row.ip || '—' %></dd></div>
      </dl>
    </section>

    <section class="gwa-card">
      <h2>Specification</h2>
      <pre class="gwa-pre"><%= row.spec %></pre>
    </section>

    <section class="gwa-card">
      <h2>Manage</h2>
      <form method="post" action="/admin/quotes/<%= row.id %>/status" class="gwa-form gwa-form--row">
        <input type="hidden" name="_csrf" value="<%= csrf %>">
        <label class="gwa-field">
          <span>Status</span>
          <select name="status">
            <% statuses.forEach(function (s) { %>
              <option value="<%= s %>" <%= s === row.status ? 'selected' : '' %>><%= s.replace('_', ' ') %></option>
            <% }); %>
          </select>
        </label>
        <button class="gwa-btn gwa-btn--primary" type="submit">Update status</button>
      </form>
      <form method="post" action="/admin/quotes/<%= row.id %>/delete" class="gwa-inline-form"
            onsubmit="return confirm('Delete this lead? This cannot be undone.');">
        <input type="hidden" name="_csrf" value="<%= csrf %>">
        <button class="gwa-btn gwa-btn--danger" type="submit">Delete lead</button>
      </form>
    </section>
  </main>
</div>
</body></html>
